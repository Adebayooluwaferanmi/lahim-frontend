    "assert": "^2.1.0",
    "bootstrap": "~4.4.1",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.0",
    "date-fns": "^3.6.0",
    "escape-string-regexp": "~4.0.0",
    "i18next": "~19.4.0",
    "i18next-browser-languagedetector": "~4.1.0",
    "lodash": "^4.17.15",
    "nanoid": "^5.0.0",
    "pouchdb": "~7.2.1",
    "pouchdb-adapter-memory": "~7.2.1",
    "pouchdb-find": "~7.2.1",
    "pouchdb-quick-search": "~1.3.0",
    "process": "^0.11.10",
    "react": "^18.3.0",
    "react-bootstrap": "^2.10.0",
    "react-bootstrap-typeahead": "^6.0.0",
    "react-dom": "^18.3.0",
    "react-i18next": "~11.4.0",
    "react-router": "^6.26.0",
    "react-router-dom": "^6.26.0",
    "sass": "^1.77.0",
    "socket.io-client": "^4.7.5",
    "stream-browserify": "^3.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.0",
    "uuid": "^8.0.0",
    "validator": "^13.0.0",
    "zustand": "^4.5.0"
  },
  "resolutions": {
    "moment": "2.24.0"
  },
  "comments": {
    "resolutions": "Added this key as temp fix https://github.com/moment/moment/issues/5484"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Adebayooluwaferanmi/lahim-frontend.git"
  },
  "author": "LaHIM Team",
  "contributors": [
    "Maksim Sinik",
    "Stefano Casasola"
  ],
  "devDependencies": {
    "@commitlint/cli": "~8.3.5",
    "@commitlint/config-conventional": "~8.3.4",
    "@commitlint/core": "~8.3.5",
    "@commitlint/prompt": "~8.3.5",
    "@playwright/test": "^1.41.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.0.0",
    "@testing-library/react-hooks": "~3.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/lodash": "^4.14.150",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^20.14.0",
    "@types/pouchdb": "~6.4.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^7.0.0",
    "@types/validator": "~13.0.0",
    "typescript-eslint": "^8.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^2.1.0",
    "commitizen": "~4.0.3",
    "commitlint-config-cz": "~0.13.0",
    "cross-env": "~7.0.0",
    "cz-conventional-changelog": "~3.1.0",
    "dateformat": "~3.0.3",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "history": "~4.10.1",
    "lint-staged": "~10.2.0",
    "memdown": "~5.1.0",
    "prettier": "~2.0.4",
    "process": "^0.11.10",
    "source-map-explorer": "^2.2.2",
    "standard-version": "~7.1.0",
    "vite": "^7.2.6",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vitest": "^2.1.0"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "build:check": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "analyze": "source-map-explorer 'build/assets/*.js'",
    "commit": "npx git-cz",
    "prepublishOnly": "npm run build",
    "test": "npm exec vitest",
    "test:ui": "npm exec vitest -- --ui",
    "test:coverage": "npm exec vitest -- --coverage",
    "test:ci": "npm exec vitest -- run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix",
    "lint-staged": "lint-staged",
    "commitlint": "commitlint",
    "coveralls": "npm run test:ci -- --coverage --watchAll=false && cat ./coverage/lcov.info"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "npm run lint:fix",
      "npm run test:ci",
      "git add ."
    ]
  }
}
